lane :beta do
  match(
    type: "appstore",
    git_url: ENV["MATCH_GIT_URL"],
    git_branch: "main",
    git_basic_authorization: ENV["MATCH_GIT_PRIVATE_TOKEN"]
  )

  build_app(
    scheme: ENV["APP_SCHEME"],
    export_method: "app-store",
    clean: true,
    output_directory: "./build",
    output_name: "#{ENV['APP_SCHEME']}.ipa"
  )

  upload_to_testappio(
    api_token: ENV["TESTAPPIO_API_TOKEN"],
    app_id: ENV["TESTAPPIO_APP_ID"],
    ipa: "./build/#{ENV['APP_SCHEME']}.ipa"
  )
end

end

