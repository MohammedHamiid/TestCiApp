default_platform(:ios)

platform :ios do
  desc "Build and upload the app to TestApp.io"
  lane :beta do
    build_app(
      scheme: "TestCiApp",          # غيّر الاسم حسب مشروعك
      export_method: "ad-hoc",      # أو app-store حسب توقيعك
      output_directory: "./build",  # مجلد حفظ الـ ipa
      output_name: "TestCiApp.ipa"  # اسم ملف الـ ipa
    )
    upload_to_testappio(
      token: ENV['TESTAPPIO_API_TOKEN'],  # اسم المتغير متوافق مع secret في GitHub
      file: "./build/TestCiApp.ipa"
    )
  end
end
